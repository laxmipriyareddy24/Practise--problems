package javapractice;

public class pattern5 {

	public static void main(String[] args) {
		// TODO Auto-generated method stub
		int n =7;

        for (int i = n; i >= 1; i--) {
            for (int s = 0; s < n - i; s++) {
                System.out.print("  ");
            }

            for (char ch = 'A'; ch < 'A' + i; ch++) {
                System.out.print(ch + " ");
            }

            System.out.println();
        }
	}

}
